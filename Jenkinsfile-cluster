pipeline {
    agent {
        label 'linux' 
        }
    environment {
        my_aws_access= credentials('AWS-CRED')
    }
    tools {
        terraform 'my-terraform'
    }
    stages {
        stage('Terraform Init') {
            steps {
	        sh ' cd terraform'
                sh 'terraform init'
            }
        }
         stage('Terraform fmt-validate') {
            steps {
                sh '''
                terraform fmt
                terraform validate
                '''
            }
        }
         stage('Terraform plan') {
            steps {
                sh 'terraform plan'
            }
        }
         stage('Terraform APPLY') {
            steps {
                sh 'terraform apply -auto-approve'
            }
        }
    }
}

