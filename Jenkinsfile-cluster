pipeline {
    agent any
    tools {
        terraform 'my-terraform'
    }
    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'prod'], description: 'Select environment')
        choice(name: 'ACTION', choices: ['apply', 'destroy'], description: 'Choose Terraform action')
    }
    stages {
        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }
        stage('Terraform Apply') {
            when {
                expression { return params.ACTION == 'apply' }
            }
            steps {
                sh "terraform apply -var environment=${params.ENVIRONMENT} -auto-approve"
            }
        }
        stage('Terraform Destroy') {
            when {
                expression { return params.ACTION == 'destroy' }
            }
            steps {
                sh "terraform destroy -var environment=${params.ENVIRONMENT} -auto-approve"
            }
        }
    }
}


